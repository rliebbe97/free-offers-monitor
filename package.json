{
  "name": "free-offers-monitor",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "eval": "pnpm --filter worker exec tsx ../../evals/run-eval.ts",
    "demo": "pnpm --filter worker exec tsx ../../evals/demo.ts",
    "seed:dashboard": "pnpm --filter worker exec tsx ../../evals/seed-dashboard.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:generate": "pnpm --filter @repo/db db:generate"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
